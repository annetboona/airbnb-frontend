# ── Local dev ──────────────────────────────────────────────────────────────────
# Leave VITE_API_URL empty in dev — Vite proxy forwards /api/v1/* to Render.
VITE_API_URL=http://localhost:3000/api/v1

# ── Production ─────────────────────────────────────────────────────────────────
# Uncomment and set when deploying the frontend (e.g. to Vercel / Netlify):
# VITE_API_URL=https://airbnb-xr0i.onrender.com/api/v1
